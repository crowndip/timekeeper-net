<Window x:Class="ParentalControl.Client.Windows.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parental Control Warning"
        Height="250" Width="450"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#FFF3F3F3">
    <Border BorderBrush="#FF6B6B" BorderThickness="3" CornerRadius="10" Padding="20">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⚠️ Time Limit Warning" 
                           FontSize="28" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#FF6B6B"
                           Margin="0,0,0,20"/>
                
                <TextBlock x:Name="TimeRemainingText"
                           Text="5:00" 
                           FontSize="56" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#DC143C"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="minutes remaining"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Foreground="#555"
                           Margin="0,0,0,30"/>
                
                <TextBlock Text="Please save your work and log off."
                           FontSize="16"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#333"
                           MaxWidth="350"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Your session will end automatically when time expires."
                           FontSize="14"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#666"
                           MaxWidth="350"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
