@inject HttpClient Http
@inject NavigationManager Navigation

@code {
    protected bool isReadOnly = true;

    protected async Task CheckAuthStatus()
    {
        try
        {
            var response = await Http.GetAsync("/api/auth/status");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthStatusResponse>();
                isReadOnly = !(result?.Authenticated ?? false);
            }
            else
            {
                isReadOnly = true;
            }
        }
        catch
        {
            isReadOnly = true;
        }
    }

    protected void RequestAuth()
    {
        Navigation.NavigateTo("/admin-auth");
    }

    private class AuthStatusResponse
    {
        public bool Authenticated { get; set; }
    }
}
