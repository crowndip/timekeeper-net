@page "/users"
@using ParentalControl.WebService.Models
@using ParentalControl.WebService.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using System.Net.Http.Json
@inject AppDbContext DbContext
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Users Management</PageTitle>

<style>
    .page-container {
        padding: 16px;
        max-width: 1200px;
        margin: 0 auto;
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        gap: 12px;
        flex-wrap: wrap;
    }
    
    .page-title {
        margin: 0;
        font-size: 1.5rem;
    }
    
    .header-actions {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }
    
    .btn {
        padding: 10px 16px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
        font-size: 14px;
    }
    
    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
        }
        
        .page-title {
            font-size: 1.25rem;
        }
        
        .header-actions {
            width: 100%;
        }
        
        .btn {
            flex: 1;
            text-align: center;
            padding: 12px 16px;
        }
    }
</style>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">👥 Users Management @(isReadOnly ? "(Read-Only)" : "")</h1>
        <div class="header-actions">
            @if (isReadOnly)
            {
                <button @onclick="RequestAdminAuth" class="btn" style="background: #f59e0b; color: white;">
                    🔒 Unlock
                </button>
            }
            <button @onclick="ShowAddDialog" disabled="@isReadOnly" class="btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; opacity: @(isReadOnly ? "0.5" : "1"); cursor: @(isReadOnly ? "not-allowed" : "pointer");">
                + Add User
            </button>
            <a href="/" class="btn" style="background: #6b7280; color: white;">← Dashboard</a>
        </div>
    </div>

    @if (loading)
    {
        <p>Loading users...</p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="padding: 15px; background: #fee; border: 1px solid #f00; border-radius: 8px; color: #c00; margin-bottom: 20px;">
            @errorMessage
        </div>
    }
    else
    {
        <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            <thead style="background: #f3f4f6;">
                <tr>
                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e5e7eb;">Username</th>
                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e5e7eb;">Full Name</th>
                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e5e7eb;">Email</th>
                    <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e5e7eb;">Account Type</th>
                    <th style="padding: 12px; text-align: center; border-bottom: 2px solid #e5e7eb;">Active</th>
                    <th style="padding: 12px; text-align: center; border-bottom: 2px solid #e5e7eb;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr style="border-bottom: 1px solid #e5e7eb;">
                        <td style="padding: 12px;">@user.Username</td>
                        <td style="padding: 12px;">@(user.FullName ?? "-")</td>
                        <td style="padding: 12px;">@(user.Email ?? "-")</td>
                        <td style="padding: 12px;">
                            <span style="padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; background: @GetAccountTypeBg(user.AccountType); color: white;">
                                @user.AccountType
                            </span>
                        </td>
                        <td style="padding: 12px; text-align: center;">
                            <button @onclick="() => ToggleActive(user)" style="padding: 4px 12px; border: none; border-radius: 4px; cursor: pointer; background: @(user.IsActive ? "#10b981" : "#6b7280"); color: white;">
                                @(user.IsActive ? "Active" : "Inactive")
                            </button>
                        </td>
                        <td style="padding: 12px; text-align: center;">
                            <button @onclick="() => ShowEditDialog(user)" disabled="@isReadOnly" style="padding: 6px 12px; margin-right: 5px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: @(isReadOnly ? "not-allowed" : "pointer"); opacity: @(isReadOnly ? "0.5" : "1");">Edit</button>
                            <button @onclick="() => ShowTimeAdjustDialog(user)" disabled="@isReadOnly" style="padding: 6px 12px; margin-right: 5px; background: #10b981; color: white; border: none; border-radius: 4px; cursor: @(isReadOnly ? "not-allowed" : "pointer"); opacity: @(isReadOnly ? "0.5" : "1");">⏱️ Time</button>
                            <button @onclick="() => DeleteUser(user)" disabled="@isReadOnly" style="padding: 6px 12px; background: #ef4444; color: white; border: none; border-radius: 4px; cursor: @(isReadOnly ? "not-allowed" : "pointer"); opacity: @(isReadOnly ? "0.5" : "1");">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (users.Count == 0)
        {
            <p style="text-align: center; padding: 40px; color: #6b7280;">No users found. Click "Add User" to create one.</p>
        }
    }
</div>

@if (showDialog)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000;" @onclick="CloseDialog">
        <div style="background: white; padding: 30px; border-radius: 12px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation="true">
            <h2 style="margin-top: 0;">@(editingUser == null ? "Add User" : "Edit User")</h2>
            
            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; font-weight: 600;">Username *</label>
                <input @bind="formUser.Username" disabled="@(editingUser != null)" style="width: 100%; padding: 8px; border: 1px solid #d1d5db; border-radius: 4px;" />
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; font-weight: 600;">Full Name</label>
                <input @bind="formUser.FullName" style="width: 100%; padding: 8px; border: 1px solid #d1d5db; border-radius: 4px;" />
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; font-weight: 600;">Email</label>
                <input @bind="formUser.Email" type="email" style="width: 100%; padding: 8px; border: 1px solid #d1d5db; border-radius: 4px;" />
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; font-weight: 600;">Account Type *</label>
                <select @bind="formUser.AccountType" style="width: 100%; padding: 8px; border: 1px solid #d1d5db; border-radius: 4px;">
                    <option value="@AccountType.Unassigned">Unassigned (Needs configuration)</option>
                    <option value="@AccountType.Child">Child (Supervised)</option>
                    <option value="@AccountType.Parent">Parent (No limits)</option>
                    <option value="@AccountType.Technical">Technical (System)</option>
                </select>
            </div>

            <div style="margin-bottom: 20px;">
                <label style="display: flex; align-items: center; cursor: pointer;">
                    <input type="checkbox" @bind="formUser.IsActive" style="margin-right: 8px;" />
                    <span>Active</span>
                </label>
            </div>

            @if (!string.IsNullOrEmpty(dialogError))
            {
                <div style="padding: 10px; background: #fee; border: 1px solid #f00; border-radius: 4px; color: #c00; margin-bottom: 15px;">
                    @dialogError
                </div>
            }

            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <button @onclick="CloseDialog" style="padding: 10px 20px; background: #6b7280; color: white; border: none; border-radius: 4px; cursor: pointer;">Cancel</button>
                <button @onclick="SaveUser" disabled="@saving" style="padding: 10px 20px; background: #10b981; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    @(saving ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

@if (showTimeDialog)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000;" @onclick="CloseTimeDialog">
        <div style="background: white; padding: 30px; border-radius: 12px; max-width: 600px; width: 90%;" @onclick:stopPropagation="true">
            <h2 style="margin-top: 0;">⏱️ Adjust Time for @timeAdjustUser?.Username</h2>
            
            @if (timeStatus != null)
            {
                <div style="background: #f3f4f6; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                    <div style="margin-bottom: 10px;">
                        <strong>Time Remaining:</strong> @(timeStatus.TimeRemaining == int.MaxValue ? "Unlimited" : $"{timeStatus.TimeRemaining} minutes")
                    </div>
                    <div style="margin-bottom: 10px;">
                        <strong>Used Today:</strong> @timeStatus.UsedToday minutes
                    </div>
                    <div>
                        <strong>Adjustments Today:</strong> @timeStatus.TotalAdjustments minutes
                    </div>
                </div>
            }
            
            <p style="margin-bottom: 20px; color: #666;">Add extra time for today only. This will not affect other days.</p>
            
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 20px;">
                <button @onclick="() => AdjustTime(5)" disabled="@adjusting" style="padding: 15px; background: #10b981; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; font-weight: 600;">
                    +5 min
                </button>
                <button @onclick="() => AdjustTime(15)" disabled="@adjusting" style="padding: 15px; background: #3b82f6; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; font-weight: 600;">
                    +15 min
                </button>
                <button @onclick="() => AdjustTime(30)" disabled="@adjusting" style="padding: 15px; background: #f59e0b; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; font-weight: 600;">
                    +30 min
                </button>
                <button @onclick="() => AdjustTime(60)" disabled="@adjusting" style="padding: 15px; background: #ef4444; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; font-weight: 600;">
                    +60 min
                </button>
            </div>
            
            @if (!string.IsNullOrEmpty(timeDialogMessage))
            {
                <div style="padding: 10px; background: #d1fae5; border: 1px solid #10b981; border-radius: 4px; color: #065f46; margin-bottom: 15px;">
                    @timeDialogMessage
                </div>
            }
            
            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <button @onclick="CloseTimeDialog" style="padding: 10px 20px; background: #6b7280; color: white; border: none; border-radius: 4px; cursor: pointer;">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private List<User> users = new();
    private bool loading = true;
    private string errorMessage = string.Empty;
    private bool showDialog = false;
    private User? editingUser = null;
    private User formUser = new();
    private string dialogError = string.Empty;
    private bool saving = false;
    private bool isReadOnly = true;
    
    private bool showTimeDialog = false;
    private User? timeAdjustUser = null;
    private TimeStatusResponse? timeStatus = null;
    private bool adjusting = false;
    private string timeDialogMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await CheckAdminAuth();
        await LoadUsers();
    }

    private async Task CheckAdminAuth()
    {
        var isAuth = await JS.InvokeAsync<string>("sessionStorage.getItem", "adminAuthenticated");
        isReadOnly = isAuth != "true";
    }

    private void RequestAdminAuth()
    {
        Navigation.NavigateTo("/admin-auth");
    }
    
    private async Task ShowTimeAdjustDialog(User user)
    {
        if (isReadOnly) return;
        timeAdjustUser = user;
        timeDialogMessage = string.Empty;
        await LoadTimeStatus(user.Id);
        showTimeDialog = true;
    }
    
    private async Task LoadTimeStatus(Guid userId)
    {
        try
        {
            var response = await new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) }
                .GetFromJsonAsync<ApiResponse<TimeStatusResponse>>($"/api/users/{userId}/time-status");
            timeStatus = response?.Data;
        }
        catch (Exception ex)
        {
            timeDialogMessage = $"Error loading time status: {ex.Message}";
        }
    }
    
    private async Task AdjustTime(int minutes)
    {
        if (timeAdjustUser == null) return;
        adjusting = true;
        timeDialogMessage = string.Empty;
        
        try
        {
            var client = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            var response = await client.PostAsJsonAsync($"/api/users/{timeAdjustUser.Id}/adjust-time", 
                new { MinutesAdjustment = minutes, Reason = "Manual adjustment by admin" });
            
            if (response.IsSuccessStatusCode)
            {
                timeDialogMessage = $"✅ Added {minutes} minutes for today";
                await LoadTimeStatus(timeAdjustUser.Id);
            }
            else
            {
                timeDialogMessage = "❌ Failed to adjust time";
            }
        }
        catch (Exception ex)
        {
            timeDialogMessage = $"❌ Error: {ex.Message}";
        }
        finally
        {
            adjusting = false;
        }
    }
    
    private void CloseTimeDialog()
    {
        showTimeDialog = false;
        timeAdjustUser = null;
        timeStatus = null;
        timeDialogMessage = string.Empty;
    }
    
    private record TimeStatusResponse(int TimeRemaining, int UsedToday, int TotalAdjustments);
    private record ApiResponse<T>(bool Success, T? Data);

    private async Task LoadUsers()
    {
        loading = true;
        errorMessage = string.Empty;
        try
        {
            users = await DbContext.Users.OrderBy(u => u.Username).ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load users: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ShowAddDialog()
    {
        if (isReadOnly) return;
        editingUser = null;
        formUser = new User { IsActive = true, AccountType = AccountType.Child };
        dialogError = string.Empty;
        showDialog = true;
    }

    private void ShowEditDialog(User user)
    {
        if (isReadOnly) return;
        editingUser = user;
        formUser = new User
        {
            Id = user.Id,
            Username = user.Username,
            FullName = user.FullName,
            Email = user.Email,
            AccountType = user.AccountType,
            IsActive = user.IsActive
        };
        dialogError = string.Empty;
        showDialog = true;
    }

    private void CloseDialog()
    {
        showDialog = false;
        editingUser = null;
        dialogError = string.Empty;
    }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(formUser.Username))
        {
            dialogError = "Username is required";
            return;
        }
        
        if (formUser.Username.Length > 64 || !formUser.Username.All(c => char.IsLetterOrDigit(c) || c == '_' || c == '-' || c == '.'))
        {
            dialogError = "Username can only contain letters, numbers, _, -, . (max 64 chars)";
            return;
        }
        
        if (!string.IsNullOrWhiteSpace(formUser.Email))
        {
            if (formUser.Email.Length > 255 || !new System.ComponentModel.DataAnnotations.EmailAddressAttribute().IsValid(formUser.Email))
            {
                dialogError = "Invalid email format";
                return;
            }
        }

        saving = true;
        dialogError = string.Empty;
        try
        {
            if (editingUser == null)
            {
                // Check for duplicate username
                if (await DbContext.Users.AnyAsync(u => u.Username == formUser.Username))
                {
                    dialogError = "Username already exists";
                    saving = false;
                    return;
                }

                formUser.Id = Guid.NewGuid();
                formUser.CreatedAt = DateTime.UtcNow;
                formUser.UpdatedAt = DateTime.UtcNow;
                DbContext.Users.Add(formUser);
            }
            else
            {
                var existing = await DbContext.Users.FindAsync(editingUser.Id);
                if (existing != null)
                {
                    existing.Username = formUser.Username;
                    existing.FullName = formUser.FullName;
                    existing.Email = formUser.Email;
                    existing.AccountType = formUser.AccountType;
                    existing.IsActive = formUser.IsActive;
                    existing.UpdatedAt = DateTime.UtcNow;
                }
            }

            await DbContext.SaveChangesAsync();
            await LoadUsers();
            CloseDialog();
        }
        catch (Exception ex)
        {
            dialogError = $"Error: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleActive(User user)
    {
        if (isReadOnly) return;
        try
        {
            user.IsActive = !user.IsActive;
            user.UpdatedAt = DateTime.UtcNow;
            await DbContext.SaveChangesAsync();
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to toggle status: {ex.Message}";
        }
    }

    private async Task DeleteUser(User user)
    {
        if (isReadOnly) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete user '{user.Username}'?"))
            return;

        try
        {
            DbContext.Users.Remove(user);
            await DbContext.SaveChangesAsync();
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete user: {ex.Message}";
        }
    }

    private string GetAccountTypeBg(AccountType type) => type switch
    {
        AccountType.Unassigned => "#ef4444",
        AccountType.Child => "#f59e0b",
        AccountType.Parent => "#10b981",
        AccountType.Technical => "#6b7280",
        _ => "#6b7280"
    };
}
