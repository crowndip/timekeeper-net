@page "/"
@using ParentalControl.WebService.Services
@inject IDatabaseInitializationService DbInit
@inject NavigationManager Navigation

<PageTitle>Parental Control System</PageTitle>

@if (isChecking)
{
    <div class="text-center mt-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3">Checking system status...</p>
    </div>
}
else if (needsSetup)
{
    <div class="container mt-5">
        <div class="alert alert-warning">
            <h4 class="alert-heading">⚠️ Database Setup Required</h4>
            <p>The database has not been initialized yet.</p>
            <hr>
            <a href="/setup" class="btn btn-primary">Go to Setup Page</a>
        </div>
    </div>
}
else
{
    <h1>Parental Control System</h1>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Users</h5>
                    <p class="card-text">Manage users and accounts</p>
                    <a href="/users" class="btn btn-primary">Manage Users</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Time Profiles</h5>
                    <p class="card-text">Configure time limits</p>
                    <a href="/profiles" class="btn btn-primary">Manage Profiles</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Reports</h5>
                    <p class="card-text">View usage reports</p>
                    <a href="/reports" class="btn btn-primary">View Reports</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isChecking = true;
    private bool needsSetup = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var isInitialized = await DbInit.IsDatabaseInitializedAsync();
            needsSetup = !isInitialized;
            
            if (needsSetup)
            {
                // Redirect to setup page
                Navigation.NavigateTo("/setup", true);
            }
        }
        catch (Exception)
        {
            // If check fails, assume needs setup
            needsSetup = true;
            Navigation.NavigateTo("/setup", true);
        }
        finally
        {
            isChecking = false;
        }
    }
}
