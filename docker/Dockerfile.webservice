FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS base
WORKDIR /app
EXPOSE 80

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY ["src/ParentalControl.WebService/ParentalControl.WebService.csproj", "ParentalControl.WebService/"]
COPY ["src/ParentalControl.Shared/ParentalControl.Shared.csproj", "ParentalControl.Shared/"]
RUN dotnet restore "ParentalControl.WebService/ParentalControl.WebService.csproj"
COPY src/ .
WORKDIR "/src/ParentalControl.WebService"
RUN dotnet build "ParentalControl.WebService.csproj" -c Release -o /app/build

FROM build AS publish
RUN dotnet publish "ParentalControl.WebService.csproj" -c Release -o /app/publish

FROM base AS final
WORKDIR /app

# Install curl for health check
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

COPY --from=publish /app/publish .

# Add health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8080/ || exit 1

ENTRYPOINT ["dotnet", "ParentalControl.WebService.dll"]
